RewriteEngine On
RewriteCond %{ENV:HTTPS} !on
RewriteRule (.*) https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

#PROTECTION DES ATTAQUES PEL
<FilesMatch ".*\.(pl|pel|asp)$">
	Deny from All
</FilesMatch>
#PROTECTION DES FICHIERS DE CONFIGURATION ET DE CLASSE
<FilesMatch ".*\.(inc|class)\.php$">
	Deny from All
</FilesMatch>
<Files ~ "\.(env|json|config.js|md|xml|gitignore|gitattributes|lock|editorconfig|yml|styleci.yml)$">
     Order allow,deny
     Deny from all
 </Files>
 Options -Indexes
 <Files ~ "(artisan|package.json|webpack.mix.js)$">
     Order allow,deny
     Deny from all
 </Files>

RewriteRule ^(.*)-css-([0-9]*).css$ $1.css [L]
RewriteRule ^(.*)-js-([0-9]*).js$ $1.js [L]
